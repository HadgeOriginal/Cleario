<Page
    x:Name="RootPage"
    x:Class="Cleario.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="20">
            <StackPanel Spacing="20">
                <StackPanel Spacing="4">
                    <TextBlock Text="Continue watching"
                               FontSize="32"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="SubtitleTextBlock"
                               Opacity="0.74"
                               Text="Resume from where you left off"/>
                </StackPanel>

                <StackPanel x:Name="EmptyPanel"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="Nothing to continue"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                    <TextBlock Text="Start watching a movie or show and it will appear here."
                               TextWrapping="WrapWholeWords"
                               Opacity="0.78"
                               TextAlignment="Center"
                               MaxWidth="560"/>
                </StackPanel>

                <GridView x:Name="HistoryGrid"
                          ItemsSource="{x:Bind Items, Mode=OneWay}"
                          IsItemClickEnabled="False"
                          SelectionMode="None"
                          ItemClick="HistoryGrid_ItemClick"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>

                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,18,18"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="UseSystemFocusVisuals" Value="False"/>
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="{Binding PosterWidth}">
                                <StackPanel Spacing="8">
                                    <Grid x:Name="PosterCardRoot"
                                          Width="{Binding PosterWidth}"
                                          Height="{Binding PosterHeight}"
                                          Tag="{Binding}"
                                          Tapped="PosterBackgroundGrid_Tapped"
                                          RightTapped="PosterRoot_RightTapped"
                                          PointerEntered="PosterRoot_PointerEntered"
                                          PointerExited="PosterRoot_PointerExited"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Grid.RenderTransform>
                                        <Border Width="{Binding PosterWidth}"
                                                Height="{Binding PosterHeight}"
                                                CornerRadius="10"
                                                BorderBrush="#2CFFFFFF"
                                                BorderThickness="1"
                                                Background="Transparent">
                                            <Grid>
                                                <Image x:Name="PosterImageElement"
                                                       Source="{Binding Item.Poster}"
                                                       Stretch="UniformToFill"
                                                       Visibility="Collapsed"
                                                       ImageOpened="PosterImageElement_ImageOpened"
                                                       ImageFailed="PosterImageElement_ImageFailed"/>

                                                <Grid x:Name="PosterShimmerOverlay"
                                                      Background="#181818"
                                                      IsHitTestVisible="False">
                                                    <Border Opacity="0.9">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF1B1B1B" Offset="0"/>
                                                                <GradientStop Color="#FF2A2A2A" Offset="0.5"/>
                                                                <GradientStop Color="#FF1B1B1B" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                                <Button x:Name="PlayOverlayButton"
                                                        Content="▶"
                                                        Tag="{Binding}"
                                                        Click="PlayOverlayButton_Click"
                                                        Width="58"
                                                        Height="58"
                                                        Padding="0"
                                                        CornerRadius="29"
                                                        BorderThickness="0"
                                                        FontSize="28"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="#DD000000"
                                                        Foreground="White"
                                                        Visibility="Collapsed"
                                                        RenderTransformOrigin="0.5,0.5"
                                                        PointerEntered="PlayOverlayButton_PointerEntered"
                                                        PointerExited="PlayOverlayButton_PointerExited">
                                                    <Button.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Button.RenderTransform>
                                                </Button>
                                                <Border Height="6"
                                                        CornerRadius="3"
                                                        Background="#66FFFFFF"
                                                        VerticalAlignment="Bottom"
                                                        Margin="14,0,14,14"/>
                                                <Border Height="6"
                                                        CornerRadius="3"
                                                        Background="White"
                                                        VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Left"
                                                        Margin="14,0,14,14"
                                                        Width="{Binding ProgressWidth}"/>

                                                <Border x:Name="WatchedBadge"
                                                        Width="28"
                                                        Height="28"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="8"
                                                        CornerRadius="14"
                                                        Background="#E0235ED8"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False">
                                                    <TextBlock Text="✓"
                                                               Foreground="White"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Border x:Name="PosterInfoOverlay"
                                                        VerticalAlignment="Bottom"
                                                        Margin="8,8,8,26"
                                                        Padding="8,6"
                                                        Background="#D0000000"
                                                        CornerRadius="8"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8"
                                                                VerticalAlignment="Center">
                                                        <TextBlock x:Name="PosterYearTextBlock"
                                                                   Foreground="White"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>

                                                        <StackPanel x:Name="PosterImdbPanel"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    VerticalAlignment="Center">
                                                            <Border Background="#FFF5C518"
                                                                    CornerRadius="4"
                                                                    Padding="5,1">
                                                                <TextBlock Text="IMDb"
                                                                           Foreground="Black"
                                                                           FontSize="10"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock x:Name="PosterImdbTextBlock"
                                                                       Foreground="#FFF5C518"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="2"
                                               TextAlignment="Center"/>
                                </StackPanel>

                                <Button Content="✕"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        CornerRadius="14"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="8"
                                        Background="#BB000000"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Tag="{Binding}"
                                        Click="DismissButton_Click"/>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
