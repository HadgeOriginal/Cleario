<Page
    x:Name="RootPage"
    x:Class="Cleario.Pages.DiscoverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="14"
                    Margin="0,0,0,18">

            <ComboBox x:Name="TypeComboBox"
                      Width="150"
                      MinWidth="150"
                      Height="40"
                      SelectionChanged="TypeComboBox_SelectionChanged"/>

            <ComboBox x:Name="CatalogComboBox"
                      Width="190"
                      MinWidth="190"
                      Height="40"
                      SelectionChanged="CatalogComboBox_SelectionChanged"/>

            <ComboBox x:Name="GenreComboBox"
                      Width="170"
                      MinWidth="170"
                      Height="40"
                      SelectionChanged="GenreComboBox_SelectionChanged"/>
        </StackPanel>

        <GridView x:Name="PosterGrid"
                  Grid.Row="1"
                  ItemsSource="{x:Bind Items, Mode=OneWay}"
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  ItemClick="Poster_ItemClick"
                  Loaded="PosterGrid_Loaded"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,18,18"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="UseSystemFocusVisuals" Value="False"/>
                </Style>
            </GridView.ItemContainerStyle>

            
            <GridView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="{Binding ElementName=RootPage, Path=PosterCardWidth}"
                                Spacing="8">
                        <Grid x:Name="PosterCardRoot"
                              Width="{Binding ElementName=RootPage, Path=PosterCardWidth}"
                              Height="{Binding ElementName=RootPage, Path=PosterCardHeight}"
                              Tag="{Binding}"
                              PointerEntered="PosterCard_PointerEntered"
                              PointerExited="PosterCard_PointerExited"
                              RightTapped="PosterCard_RightTapped"
                              Loaded="PosterCard_Loaded"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <Border x:Name="PosterCardBorder"
                                    Width="{Binding ElementName=RootPage, Path=PosterCardWidth}"
                                    Height="{Binding ElementName=RootPage, Path=PosterCardHeight}"
                                    CornerRadius="10"
                                    BorderBrush="#2CFFFFFF"
                                    BorderThickness="1"
                                    Background="Transparent">
                                <Grid>
                                    <Image x:Name="PosterImageElement"
                                           Source="{Binding Poster}"
                                           Stretch="UniformToFill"
                                           Tag="{Binding}"
                                           Visibility="Collapsed"
                                           ImageFailed="Poster_ImageFailed"
                                           ImageOpened="Poster_ImageOpened"/>

                                    <Grid x:Name="PosterShimmerOverlay"
                                          Background="#181818"
                                          IsHitTestVisible="False">
                                        <Border Opacity="0.9">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF1B1B1B" Offset="0"/>
                                                    <GradientStop Color="#FF2A2A2A" Offset="0.5"/>
                                                    <GradientStop Color="#FF1B1B1B" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                    </Grid>

                                    <Border x:Name="WatchedBadge"
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="8"
                                            CornerRadius="14"
                                            Background="#E0235ED8"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <TextBlock Text="✓"
                                                   Foreground="White"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center"/>
                                    </Border>

                                    <Border x:Name="PosterInfoOverlay"
                                            VerticalAlignment="Bottom"
                                            Margin="8"
                                            Padding="8,6"
                                            Background="#D0000000"
                                            CornerRadius="8"
                                            HorizontalAlignment="Center"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="PosterYearTextBlock"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>

                                            <StackPanel x:Name="PosterImdbPanel"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Border Background="#FFF5C518"
                                                        CornerRadius="4"
                                                        Padding="5,1">
                                                    <TextBlock Text="IMDb"
                                                               Foreground="Black"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock x:Name="PosterImdbTextBlock"
                                                           Foreground="#FFF5C518"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
</StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding Name}"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords"
                                   MaxLines="2"/>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>

        </GridView>
    </Grid>
</Page>