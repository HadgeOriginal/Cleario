<Page
    x:Name="RootPage"
    x:Class="Cleario.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20">
            <StackPanel Spacing="20">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="SearchTitleTextBlock"
                               FontSize="32"
                               FontWeight="Bold"
                               Text="Search"/>
                    <TextBlock x:Name="SearchSubtitleTextBlock"
                               Opacity="0.74"
                               Text="Search results"/>
                </StackPanel>

                <StackPanel x:Name="LoadingPanel"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <ProgressRing IsActive="True"
                                  Width="54"
                                  Height="54"
                                  HorizontalAlignment="Center"/>
                    <TextBlock Text="Searching..."
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="EmptyPanel"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No results found"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                    <TextBlock x:Name="EmptyBodyTextBlock"
                               Opacity="0.78"
                               TextWrapping="WrapWholeWords"
                               TextAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="MoviesSection"
                            Spacing="14"
                            Visibility="Collapsed">
                    <TextBlock x:Name="MoviesHeaderTextBlock"
                               Text="Popular - Movie"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <GridView x:Name="MovieGrid"
                              ItemsSource="{x:Bind MovieResults, Mode=OneWay}"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              ItemClick="Poster_ItemClick"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,18,18"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="{Binding ElementName=RootPage, Path=PosterCardWidth}" Spacing="8">
                                    <Grid x:Name="PosterCardRoot"
                                          Width="{Binding ElementName=RootPage, Path=PosterCardWidth}"
                                          Height="{Binding ElementName=RootPage, Path=PosterCardHeight}"
                                          Tag="{Binding}"
                                          PointerEntered="PosterCard_PointerEntered"
                                          PointerExited="PosterCard_PointerExited"
                                          RightTapped="PosterCard_RightTapped"
                                          Loaded="PosterCard_Loaded"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Grid.RenderTransform>
                                        <Border Width="{Binding ElementName=RootPage, Path=PosterCardWidth}" Height="{Binding ElementName=RootPage, Path=PosterCardHeight}" CornerRadius="10" BorderBrush="#2CFFFFFF" BorderThickness="1" Background="#0D131313">
                                            <Grid>
                                                <Image x:Name="PosterImageElement"
                                                       Source="{Binding Poster}"
                                                       Stretch="UniformToFill"
                                                       Tag="{Binding}"
                                                       Visibility="Collapsed"
                                                       ImageFailed="Poster_ImageFailed"
                                                       ImageOpened="Poster_ImageOpened"/>
                                                <Grid x:Name="PosterShimmerOverlay" Background="#181818" IsHitTestVisible="False">
                                                    <Border Opacity="0.9">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF1B1B1B" Offset="0"/>
                                                                <GradientStop Color="#FF2A2A2A" Offset="0.5"/>
                                                                <GradientStop Color="#FF1B1B1B" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                                <Border x:Name="WatchedBadge"
                                                        Width="28"
                                                        Height="28"
                                                        CornerRadius="14"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="8"
                                                        Background="#E0235ED8"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False">
                                                    <TextBlock Text="✓"
                                                               Foreground="White"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Border x:Name="PosterInfoOverlay" VerticalAlignment="Bottom" Margin="8" Padding="8,6" Background="#D0000000" CornerRadius="8" HorizontalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="PosterYearTextBlock" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <StackPanel x:Name="PosterImdbPanel" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                            <Border Background="#FFF5C518" CornerRadius="4" Padding="5,1">
                                                                <TextBlock Text="IMDb" Foreground="Black" FontSize="10" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock x:Name="PosterImdbTextBlock" Foreground="#FFF5C518" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
</StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxLines="2"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <StackPanel x:Name="SeriesSection"
                            Spacing="14"
                            Visibility="Collapsed">
                    <TextBlock x:Name="SeriesHeaderTextBlock"
                               Text="Popular - Series"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                    <GridView x:Name="SeriesGrid"
                              ItemsSource="{x:Bind SeriesResults, Mode=OneWay}"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              ItemClick="Poster_ItemClick"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,18,18"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="{Binding ElementName=RootPage, Path=PosterCardWidth}" Spacing="8">
                                    <Grid x:Name="PosterCardRoot"
                                          Width="{Binding ElementName=RootPage, Path=PosterCardWidth}"
                                          Height="{Binding ElementName=RootPage, Path=PosterCardHeight}"
                                          Tag="{Binding}"
                                          PointerEntered="PosterCard_PointerEntered"
                                          PointerExited="PosterCard_PointerExited"
                                          RightTapped="PosterCard_RightTapped"
                                          Loaded="PosterCard_Loaded"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Grid.RenderTransform>
                                        <Border Width="{Binding ElementName=RootPage, Path=PosterCardWidth}" Height="{Binding ElementName=RootPage, Path=PosterCardHeight}" CornerRadius="10" BorderBrush="#2CFFFFFF" BorderThickness="1" Background="#0D131313">
                                            <Grid>
                                                <Image x:Name="PosterImageElement"
                                                       Source="{Binding Poster}"
                                                       Stretch="UniformToFill"
                                                       Tag="{Binding}"
                                                       Visibility="Collapsed"
                                                       ImageFailed="Poster_ImageFailed"
                                                       ImageOpened="Poster_ImageOpened"/>
                                                <Grid x:Name="PosterShimmerOverlay" Background="#181818" IsHitTestVisible="False">
                                                    <Border Opacity="0.9">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF1B1B1B" Offset="0"/>
                                                                <GradientStop Color="#FF2A2A2A" Offset="0.5"/>
                                                                <GradientStop Color="#FF1B1B1B" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                                <Border x:Name="WatchedBadge"
                                                        Width="28"
                                                        Height="28"
                                                        CornerRadius="14"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="8"
                                                        Background="#E0235ED8"
                                                        Visibility="Collapsed"
                                                        IsHitTestVisible="False">
                                                    <TextBlock Text="✓"
                                                               Foreground="White"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <Border x:Name="PosterInfoOverlay" VerticalAlignment="Bottom" Margin="8" Padding="8,6" Background="#D0000000" CornerRadius="8" HorizontalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="PosterYearTextBlock" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <StackPanel x:Name="PosterImdbPanel" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                            <Border Background="#FFF5C518" CornerRadius="4" Padding="5,1">
                                                                <TextBlock Text="IMDb" Foreground="Black" FontSize="10" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock x:Name="PosterImdbTextBlock" Foreground="#FFF5C518" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
</StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" TextWrapping="WrapWholeWords" MaxLines="2"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
