<Page
    x:Name="RootPage"
    x:Class="Cleario.Pages.DetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Image x:Name="PageBackgroundImage"
               Stretch="UniformToFill"
               Opacity="0.28"
               ImageFailed="PageBackgroundImage_ImageFailed"/>

        <Border Background="#96000000"
                CornerRadius="12"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="560"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="18"
                            Padding="18">

                    <Button Content="← Back"
                            Click="BackButton_Click"
                            Padding="14,8"
                            HorizontalAlignment="Left"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="PosterHost"
                              Grid.Column="0"
                              MinHeight="170"
                              VerticalAlignment="Top"
                              RightTapped="PosterHost_RightTapped">
                            <Image x:Name="PosterImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   ImageFailed="PosterImage_ImageFailed"/>
                            <Border x:Name="PosterWatchedBadge"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="16"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Background="#E0235ED8"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <TextBlock Text="✓"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="2"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TitleTextBlock"
                                       FontSize="50"
                                       FontWeight="Bold"
                                       TextWrapping="WrapWholeWords"
                                       Text="Loading..."/>

                            <StackPanel Orientation="Horizontal"
                                        Spacing="14"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="FactsTextBlock"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Opacity="0.9"
                                           VerticalAlignment="Center"/>

                                <Button x:Name="ImdbButton"
                                        Click="ImdbButton_Click"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Border Background="#FFF5C518"
                                               CornerRadius="4"
                                               Padding="6,2"
                                               VerticalAlignment="Center">
                                            <TextBlock Text="IMDb"
                                                       Foreground="Black"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="ImdbRatingTextBlock"
                                                   FontSize="19"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFF5C518"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock x:Name="GenresTextBlock"
                                       FontSize="16"
                                       Opacity="0.88"
                                       TextWrapping="WrapWholeWords"/>

                            <TextBlock x:Name="CastTextBlock"
                                       FontSize="16"
                                       Opacity="0.88"
                                       TextWrapping="WrapWholeWords"/>

                            <TextBlock x:Name="DirectorsTextBlock"
                                       FontSize="16"
                                       Opacity="0.88"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#18000000"
                            BorderBrush="#26FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Summary"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="DescriptionTextBlock"
                                       Text="Loading..."
                                       FontSize="15"
                                       Opacity="0.9"
                                       TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="LibraryToggleButton"
                                Content="Add to Library"
                                Click="LibraryToggleButton_Click"
                                HorizontalAlignment="Left"
                                Padding="16,10"/>
                        <Button x:Name="WatchedToggleButton"
                                Content="Mark as watched"
                                Click="WatchedToggleButton_Click"
                                HorizontalAlignment="Left"
                                Padding="16,10"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Background="#B8141414"
                    BorderBrush="#252525"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="FilterAndSeasonPanel"
                          Grid.Row="0"
                          Margin="0,0,0,12"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="AddonFilterComboBox"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  SelectionChanged="AddonFilterComboBox_SelectionChanged"/>

                        <ComboBox x:Name="SeasonComboBox"
                                  Grid.Column="1"
                                  MinWidth="0"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Visibility="Collapsed"
                                  SelectionChanged="SeasonComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Tag="{Binding}" RightTapped="SeasonOption_RightTapped">
                                        <TextBlock Text="{Binding Label}"/>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid x:Name="EpisodeSelectorsPanel"
                          Grid.Row="1"
                          Margin="0,0,0,14"
                          Visibility="Collapsed">
                        <ComboBox x:Name="EpisodeComboBox"
                                  MinWidth="0"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  SelectionChanged="EpisodeComboBox_SelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Tag="{Binding}" RightTapped="EpisodeOption_RightTapped">
                                        <TextBlock Text="{Binding EpisodeLabel}"/>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Margin="0,0,0,12"
                                Spacing="10">
                        <Grid x:Name="SelectedEpisodeHeaderPanel"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SelectedEpisodeHeaderTextBlock"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="WrapWholeWords"/>
                            <Button x:Name="BackToEpisodesButton"
                                    Grid.Column="1"
                                    Content="Episodes"
                                    Click="BackToEpisodesButton_Click"
                                    Padding="12,6"
                                    Margin="12,0,0,0"/>
                        </Grid>

                        <StackPanel x:Name="StreamsProgressPanel"
                                    Spacing="8"
                                    Visibility="Collapsed">
                            <Grid>
                                <TextBlock x:Name="StreamsProgressTextBlock"
                                           Text="Loading addons: 0/0"
                                           Opacity="0.82"/>
                                <TextBlock x:Name="StreamsProgressStreamsTextBlock"
                                           HorizontalAlignment="Right"
                                           Opacity="0.62"/>
                            </Grid>
                            <ProgressBar x:Name="StreamsProgressBar"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="0"
                                         Height="4"
                                         Foreground="White"
                                         Background="#33FFFFFF"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="3">
                        <ListView x:Name="FullEpisodesListView"
                                  Visibility="Collapsed"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Button Tag="{Binding}"
                                            Click="FullEpisodeButton_Click"
                                            RightTapped="EpisodeOption_RightTapped"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Margin="0,0,0,10">
                                        <Border Background="#14000000"
                                                BorderBrush="#33FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10">
                                            <Grid ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="132"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Width="132"
                                                      Height="74"
                                                      VerticalAlignment="Top">
                                                    <Image Source="{Binding ThumbnailDisplayUrl}"
                                                           Stretch="UniformToFill"
                                                           Opacity="{Binding EpisodeImageOpacity}"/>
                                                    <Border Background="#CC101010"
                                                            Visibility="{Binding EpisodeOverlayVisibility}">
                                                        <TextBlock Text="{Binding EpisodeOverlayText}"
                                                                   FontSize="11"
                                                                   Opacity="0.78"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Column="1"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <TextBlock Text="{Binding EpisodeNumberText}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Opacity="0.82"/>
                                                        <TextBlock Text="{Binding DisplayTitle}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="WrapWholeWords"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ReleaseDateLabel}"
                                                               FontSize="12"
                                                               Opacity="0.62"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Background="#22FFFFFF"
                                                        BorderBrush="#44FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="8"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding WatchedBadgeVisibility}">
                                                    <FontIcon Glyph="&#xE73E;"
                                                              FontSize="15"
                                                              Foreground="White"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel x:Name="StreamsLoadingPanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="14">
                            <ProgressRing IsActive="True"
                                          Width="54"
                                          Height="54"
                                          HorizontalAlignment="Center"/>
                            <TextBlock x:Name="StreamsLoadingTitleTextBlock"
                                       Text="Loading streams..."
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="StreamsLoadingSubtitleTextBlock"
                                       Text="Checking your enabled addons."
                                       Opacity="0.72"
                                       TextAlignment="Center"/>
                        </StackPanel>

                        <StackPanel x:Name="NoStreamsPanel"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <TextBlock x:Name="NoStreamsTitleTextBlock"
                                       Text="No streams found"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="NoStreamsBodyTextBlock"
                                       TextWrapping="WrapWholeWords"
                                       Opacity="0.8"
                                       MaxWidth="520"
                                       TextAlignment="Center"/>
                        </StackPanel>

                        <ListView x:Name="StreamsListView"
                                  Visibility="Collapsed"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Button Tag="{Binding}"
                                            Click="StreamButton_Click"
                                            RightTapped="StreamButton_RightTapped"
                                            IsEnabled="{Binding IsSupportedInApp}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Margin="0,0,0,10">
                                        <Border Background="#14000000"
                                                BorderBrush="{Binding ResumeBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14">
                                            <Grid>

                                                <StackPanel Spacing="6">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="WrapWholeWords"/>
                                                        <Border Background="#335AB0FF"
                                                                CornerRadius="6"
                                                                Padding="6,2"
                                                                Visibility="{Binding ResumeTagVisibility}">
                                                            <TextBlock Text="{Binding ResumeTagText}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               Opacity="0.8"
                                                               TextWrapping="WrapWholeWords"/>
                                                    <TextBlock Text="{Binding AddonName}"
                                                               Opacity="0.6"
                                                               FontSize="12"/>
                                                    <Grid Margin="0,4,0,0"
                                                          Height="{Binding ResumeBarHeight}">
                                                        <Border Height="{Binding ResumeBarHeight}"
                                                                Width="{Binding ResumeTrackWidth}"
                                                                CornerRadius="3"
                                                                Background="#66FFFFFF"
                                                                HorizontalAlignment="Left"/>
                                                        <Border Height="{Binding ResumeBarHeight}"
                                                                Width="{Binding ResumeFillWidth}"
                                                                CornerRadius="3"
                                                                Background="White"
                                                                HorizontalAlignment="Left"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
