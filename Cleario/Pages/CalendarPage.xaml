<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Cleario.Pages.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20,16,20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="PreviousMonthButton"
                    Grid.Column="0"
                    Content="←"
                    Width="40"
                    Height="40"
                    Click="PreviousMonthButton_Click"/>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                <TextBlock x:Name="MonthYearTextBlock"
                           FontSize="34"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="MonthSubtitleTextBlock"
                           Text="Library releases"
                           Opacity="0.72"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="NextMonthButton"
                    Grid.Column="2"
                    Content="→"
                    Width="40"
                    Height="40"
                    Click="NextMonthButton_Click"/>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Monday" HorizontalAlignment="Center" Opacity="0.82"/>
            <TextBlock Grid.Column="1" Text="Tuesday" HorizontalAlignment="Center" Opacity="0.82"/>
            <TextBlock Grid.Column="2" Text="Wednesday" HorizontalAlignment="Center" Opacity="0.82"/>
            <TextBlock Grid.Column="3" Text="Thursday" HorizontalAlignment="Center" Opacity="0.82"/>
            <TextBlock Grid.Column="4" Text="Friday" HorizontalAlignment="Center" Opacity="0.82"/>
            <TextBlock Grid.Column="5" Text="Saturday" HorizontalAlignment="Center" Opacity="0.82"/>
            <TextBlock Grid.Column="6" Text="Sunday" HorizontalAlignment="Center" Opacity="0.82"/>
        </Grid>

        <Border Grid.Row="2"
                Grid.Column="0"
                Margin="0,0,20,0"
                Background="Transparent"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="8">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="CalendarGrid"/>
                </ScrollViewer>

                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Visibility="Collapsed">
                    <ProgressRing Width="36" Height="36" IsActive="True"/>
                    <TextBlock Text="Loading library releases..."/>
                </StackPanel>

                <TextBlock x:Name="EmptyTextBlock"
                           Text="No release dates were found for items in your library."
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="340"
                           Visibility="Collapsed"
                           Opacity="0.78"/>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                Grid.Column="1"
                Background="Transparent"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="2">
                    <TextBlock Text="Upcoming" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock x:Name="UpcomingSubtitleTextBlock" Opacity="0.72"/>
                </StackPanel>

                <ListView x:Name="UpcomingListView"
                          Grid.Row="1"
                          Margin="0,12,0,0"
                          IsItemClickEnabled="True"
                          SelectionMode="Single"
                          ItemClick="UpcomingListView_ItemClick"
                          SelectionChanged="UpcomingListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="12"
                                    CornerRadius="14"
                                    Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="{Binding CardBorderThickness}">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DateText}" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CodeText}" Opacity="0.82"/>
                                    </Grid>

                                    <TextBlock Text="{Binding TitleText}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               TextWrapping="WrapWholeWords"/>

                                    <TextBlock Text="{Binding SubtitleText}"
                                               TextWrapping="WrapWholeWords"
                                               Opacity="0.76"
                                               Visibility="{Binding SubtitleVisibility}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
